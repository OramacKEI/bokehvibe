# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# 大文件 / 不入库的数据与权重
# 注意：git 不支持行内注释，规则与说明必须分行写

# 参考论文 PDF（本地副本，勿入库）
refs/*.pdf

# checkpoint、可视化、日志、训练产物
outputs/

# 演示/测试用图片资源
assets/

# RealBokeh / EBB! 等真实数据集
data/datasets/

# 上游仓库 BokehMe / Depth-Anything-V2（各自有 git，不嵌套入库）
third_party/

# 下载的预训练权重
checkpoints/
*.ckpt
*.pth
*.pt

# 日志文件
*.log

# 环境与编辑器
.venv/
.env
.DS_Store
.vscode/

# 内部文档（仅本地/协作者查阅，不对外公开）
CLAUDE.md
DECISIONS.md
GUIDE.md
NETWORK_DESIGN.md
PROJECT_STATUS.md
references.md

# 保留空目录占位
!**/.gitkeep
